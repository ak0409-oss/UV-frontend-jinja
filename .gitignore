# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyw
*.so
*.egg
*.egg-info/
dist/
build/
wheels/
.installed.cfg
MANIFEST

# ── Virtual environments ───────────────────────────────────────────────────────
.env
.env.*
.venv
venv/
env/
ENV/
# Keep the example env template if you add one
!.env.example

# ── Flask / instance folder ────────────────────────────────────────────────────
instance/          # Flask instance folder (config overrides, sqlite DB)
*.db               # SQLite databases (if you add persistence later)
*.sqlite
*.sqlite3

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/
pip-log.txt
pip-delete-this-directory.txt

# ── Testing ───────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/
nosetests.xml
test-results/

# ── Type checkers / linters ───────────────────────────────────────────────────
.mypy_cache/
.ruff_cache/
.pytype/

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# ── Editors ───────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# ── Deployment / CI ───────────────────────────────────────────────────────────
.vercel/
.render/
*.zip           # don't accidentally commit packaged builds

# ── Security — never commit secrets ───────────────────────────────────────────
*.pem
*.key
*.cert
*.p12
secret_key.txt